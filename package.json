{
  "name": "lightpaws-destiny-hub",
  "version": "0.1.4",
  "description": "Desktop hub for LightPaws clan Destiny 2 links.",
  "main": "src/main.js",
  "private": true,
  "author": "LightPaws",
  "repository": {
    "type": "git",
    "url": "https://github.com/LixayTheFox/lightpaws_app.git"
  },
  "scripts": {
    "start": "electron .",
    "pack": "electron-builder --dir",
    "dist": "electron-builder --win --x64",
    "publish:win": "electron-builder --win --x64 --publish always"
  },
  "dependencies": {
    "electron-updater": "^6.6.2"
  },
  "devDependencies": {
    "electron-builder": "^26.0.12",
    "electron": "^42.1.0"
  },
  "build": {
    "appId": "com.lightpaws.destinyhub",
    "productName": "LightPaws Destiny Hub",
    "directories": {
      "output": "dist"
    },
    "files": [
      "src/**/*",
      "package.json"
    ],
    "asar": true,
    "afterPack": "scripts/apply-windows-icon.js",
    "win": {
      "icon": "src/assets/app-icon.ico",
      "signAndEditExecutable": false,
      "target": [
        {
          "target": "nsis",
          "arch": [
            "x64"
          ]
        }
      ],
      "artifactName": "LightPaws-Destiny-Hub-Setup-${version}.${ext}"
    },
    "nsis": {
      "oneClick": false,
      "perMachine": false,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true,
      "installerIcon": "src/assets/app-icon.ico",
      "uninstallerIcon": "src/assets/app-icon.ico",
      "shortcutName": "LightPaws Destiny Hub"
    },
    "publish": [
      {
        "provider": "github",
        "owner": "LixayTheFox",
        "repo": "lightpaws_app",
        "releaseType": "release"
      }
    ]
  }
}
